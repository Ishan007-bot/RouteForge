<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- Project coordinates: groupId.artifactId:version uniquely identifies any Maven artifact. -->
    <groupId>com.routeforge</groupId>
    <artifactId>routeforge-parent</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>          <!-- "pom" = this module contains no code, only config -->
    <name>RouteForge (parent)</name>

    <!--
        Child modules. Maven will descend into each of these directories
        and build them in dependency order.
    -->
    <modules>
        <module>engine</module>
        <module>api</module>
    </modules>

    <!--
        Properties: shared values that children can reference with ${name}.
        We pin tool and library versions here so every module agrees on them.
    -->
    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <maven.compiler.release>21</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Library versions -->
        <osmosis.version>0.48.1</osmosis.version>
        <junit.version>5.11.3</junit.version>
        <assertj.version>3.26.3</assertj.version>
        <slf4j.version>2.0.16</slf4j.version>
        <spring.boot.version>3.4.1</spring.boot.version>
        <springdoc.version>2.7.0</springdoc.version>

        <!-- Plugin versions -->
        <maven.compiler.plugin.version>3.13.0</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.5.2</maven.surefire.plugin.version>
        <exec.maven.plugin.version>3.5.0</exec.maven.plugin.version>
    </properties>

    <!--
        dependencyManagement declares versions for libraries, but doesn't
        actually pull them in. Children that list a dependency without a
        version pick up the one declared here. Keeps versions consistent.
    -->
    <dependencyManagement>
        <dependencies>
            <!-- Spring Boot BOM: pins versions for every Spring/Jackson/Tomcat etc. artifact.
                 Children just say <dependency>spring-boot-starter-web</dependency> without a version. -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring.boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <!-- springdoc-openapi: generates Swagger UI from controllers. -->
            <dependency>
                <groupId>org.springdoc</groupId>
                <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
                <version>${springdoc.version}</version>
            </dependency>

            <!-- Osmosis: canonical Java library for OSM data.
                 osmosis-pbf pulls in osmosis-core and the protobuf bindings transitively. -->
            <dependency>
                <groupId>org.openstreetmap.osmosis</groupId>
                <artifactId>osmosis-core</artifactId>
                <version>${osmosis.version}</version>
            </dependency>
            <dependency>
                <groupId>org.openstreetmap.osmosis</groupId>
                <artifactId>osmosis-pbf</artifactId>
                <version>${osmosis.version}</version>
            </dependency>

            <!-- Logging: SLF4J API + simple console binding for now -->
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>slf4j-api</artifactId>
                <version>${slf4j.version}</version>
            </dependency>
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>slf4j-simple</artifactId>
                <version>${slf4j.version}</version>
            </dependency>

            <!-- Test stack -->
            <dependency>
                <groupId>org.junit</groupId>
                <artifactId>junit-bom</artifactId>
                <version>${junit.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.assertj</groupId>
                <artifactId>assertj-core</artifactId>
                <version>${assertj.version}</version>
                <scope>test</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!--
        Plugin versions are pinned the same way. Children pick them up
        without needing to repeat the version.
    -->
    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>${maven.compiler.plugin.version}</version>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>${maven.surefire.plugin.version}</version>
                    <configuration>
                        <!--
                            JDK 25 isn't yet recognized by the Byte Buddy version
                            bundled with Spring Boot 3.4.x → Mockito. Enabling its
                            experimental flag lets it run unmodified on JDK 25.
                            Drop this once Spring Boot ships a newer Byte Buddy.
                        -->
                        <argLine>-Dnet.bytebuddy.experimental=true</argLine>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.codehaus.mojo</groupId>
                    <artifactId>exec-maven-plugin</artifactId>
                    <version>${exec.maven.plugin.version}</version>
                </plugin>
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                    <version>${spring.boot.version}</version>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

</project>
