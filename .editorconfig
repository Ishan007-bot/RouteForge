# EditorConfig: consistent formatting across editors
# Docs: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,xml,html,css,js,jsx,ts,tsx,md}]
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab
